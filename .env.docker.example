# === Required ===
ANTHROPIC_API_KEY=sk-ant-xxxxx
PINECONE_API_KEY=pcsk_xxxxx
PINECONE_INDEX_NAME=askthevideo
VALID_ACCESS_KEYS=YOUR_ACCESS_KEY
ADMIN_TOKEN=your_admin_token

# === Residential Proxy (production only) ===
WEBSHARE_USERNAME=your_username-rotate
WEBSHARE_PASSWORD=your_password

# === Supabase (optional — persistent logging) ===
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=sb_publishable_xxxxx
APP_ENV=local

# === Pre-Supabase Historical Offsets (optional) ===
INITIAL_COST_OFFSET=0
INITIAL_INPUT_TOKENS=0
INITIAL_OUTPUT_TOKENS=0

# === Discord Alerting (optional) ===
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx

# === LangSmith Tracing (optional) ===
LANGSMITH_API_KEY=lsv2_xxxxx
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=askthevideo
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
